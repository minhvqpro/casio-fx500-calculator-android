<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E50"
    android:padding="16dp">

    <!-- Calculator Body -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="#34495E"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Brand Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CASIO"
                android:textColor="#9B59B6"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <!-- Model Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="fx-500MS"
                android:textColor="#BDC3C7"
                android:textSize="12sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp" />

            <!-- Display Screen -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#9CAF88"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/display"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="end|center_vertical"
                    android:padding="12dp"
                    android:text="0"
                    android:textColor="#2C3E50"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </androidx.cardview.widget.CardView>

            <!-- Buttons Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="5"
                android:rowCount="6"
                android:layout_marginTop="8dp">

                <!-- Row 1: Shift, Alpha, Mode, etc -->
                <Button
                    android:id="@+id/btnShift"
                    style="@style/CalcButtonFunction"
                    android:text="Shift"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btnAlpha"
                    style="@style/CalcButtonFunction"
                    android:text="Alpha"
                    android:textSize="10sp" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="MODE"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btnClear"
                    style="@style/CalcButtonClear"
                    android:text="C"
                    android:layout_columnSpan="2" />

                <!-- Row 2: Memory and functions -->
                <Button
                    android:id="@+id/btnMRC"
                    style="@style/CalcButtonMemory"
                    android:text="MRC" />

                <Button
                    android:id="@+id/btnMMinus"
                    style="@style/CalcButtonMemory"
                    android:text="M-" />

                <Button
                    android:id="@+id/btnMPlus"
                    style="@style/CalcButtonMemory"
                    android:text="M+" />

                <Button
                    style="@style/CalcButtonEmpty"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnAllClear"
                    style="@style/CalcButtonClear"
                    android:text="AC" />

                <!-- Row 3: Functions -->
                <Button
                    style="@style/CalcButtonFunction"
                    android:text="√"
                    android:id="@+id/btnSqrt" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="x²"
                    android:id="@+id/btnSquare" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="^"
                    android:id="@+id/btnPower" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="1/x"
                    android:id="@+id/btnInverse" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="%"
                    android:id="@+id/btnPercent" />

                <!-- Row 4: Numbers 7-9 and divide -->
                <Button
                    android:id="@+id/btn7"
                    style="@style/CalcButtonNumber"
                    android:text="7" />

                <Button
                    android:id="@+id/btn8"
                    style="@style/CalcButtonNumber"
                    android:text="8" />

                <Button
                    android:id="@+id/btn9"
                    style="@style/CalcButtonNumber"
                    android:text="9" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="DEL"
                    android:id="@+id/btnDelete" />

                <Button
                    android:id="@+id/btnDivide"
                    style="@style/CalcButtonOperator"
                    android:text="÷" />

                <!-- Row 5: Numbers 4-6 and multiply -->
                <Button
                    android:id="@+id/btn4"
                    style="@style/CalcButtonNumber"
                    android:text="4" />

                <Button
                    android:id="@+id/btn5"
                    style="@style/CalcButtonNumber"
                    android:text="5" />

                <Button
                    android:id="@+id/btn6"
                    style="@style/CalcButtonNumber"
                    android:text="6" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="( )"
                    android:id="@+id/btnParen" />

                <Button
                    android:id="@+id/btnMultiply"
                    style="@style/CalcButtonOperator"
                    android:text="×" />

                <!-- Row 6: Numbers 1-3 and subtract -->
                <Button
                    android:id="@+id/btn1"
                    style="@style/CalcButtonNumber"
                    android:text="1" />

                <Button
                    android:id="@+id/btn2"
                    style="@style/CalcButtonNumber"
                    android:text="2" />

                <Button
                    android:id="@+id/btn3"
                    style="@style/CalcButtonNumber"
                    android:text="3" />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="+/−"
                    android:id="@+id/btnSign" />

                <Button
                    android:id="@+id/btnSubtract"
                    style="@style/CalcButtonOperator"
                    android:text="−" />

                <!-- Row 7: 0, dot, equals, add -->
                <Button
                    android:id="@+id/btn0"
                    style="@style/CalcButtonNumber"
                    android:text="0" />

                <Button
                    android:id="@+id/btnDot"
                    style="@style/CalcButtonNumber"
                    android:text="." />

                <Button
                    style="@style/CalcButtonFunction"
                    android:text="EXP"
                    android:id="@+id/btnExp" />

                <Button
                    android:id="@+id/btnEquals"
                    style="@style/CalcButtonEquals"
                    android:text="=" />

                <Button
                    android:id="@+id/btnAdd"
                    style="@style/CalcButtonOperator"
                    android:text="+" />

            </GridLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
